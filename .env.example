# PalmFi Environment Configuration
# Copy to .env and fill in your values before running.
# Generate SECRET_KEY: python3 -c 'import secrets; print(secrets.token_hex(32))'

# REQUIRED: Flask session secret (generate a strong random one)
SECRET_KEY=

# REQUIRED: JWT signing secret (generate a strong random one)
JWT_SECRET=

# ADMIN (optional — random password generated if empty)
ADMIN_PASSWORD=

# Stripe (optional — mock mode used if empty)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (optional — falls back to console log if empty)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Twilio (optional — falls back to console log if empty)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Flask (optional — debug off by default)
FLASK_PORT=8085
FLASK_HOST=0.0.0.0
FLASK_DEBUG=false
